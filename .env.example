# =============================================================================
# WEBSITE AUTHENTICATION
# =============================================================================
# Set these to protect your website with a password
# Leave AUTH_PASSWORD empty to disable authentication (for local development)
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password_here

# =============================================================================
# AI API KEYS
# =============================================================================
# Anthropic API Key for AI-powered diagnosis feature (Claude)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key for AI-powered diagnosis feature (GPT-4o-mini)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
