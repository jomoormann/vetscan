# =============================================================================
# WEBSITE AUTHENTICATION (Legacy - single user mode)
# =============================================================================
# These credentials are used ONLY if no users exist in the database.
# When first running with multi-user auth, the system will prompt you to
# migrate this account to the database with an email address.
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password_here

# =============================================================================
# SMTP EMAIL CONFIGURATION (for Hostinger)
# =============================================================================
# Required for password reset emails and notification features
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=noreply@vetscan.net
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=noreply@vetscan.net
SMTP_FROM_NAME=VetScan

# =============================================================================
# AI API KEYS
# =============================================================================
# Anthropic API Key for AI-powered diagnosis feature (Claude)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key for AI-powered diagnosis feature (GPT-4o-mini)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
