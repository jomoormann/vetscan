[Unit]
Description=VetScan Email Import Service
After=network.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/vetscan
ExecStart=/var/www/vetscan/venv/bin/python scripts/run_email_import.py
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/www/vetscan/data /var/www/vetscan/uploads /var/www/vetscan/logs

[Install]
WantedBy=multi-user.target
